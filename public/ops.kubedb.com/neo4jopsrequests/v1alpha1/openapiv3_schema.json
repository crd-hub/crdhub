{
  "$schema": "http://json-schema.org/schema#",
  "type": "object",
  "properties": {
    "apiVersion": {
      "type": "string",
      "enum": [
        "ops.kubedb.com/v1alpha1"
      ]
    },
    "kind": {
      "type": "string",
      "enum": [
        "Neo4jOpsRequest"
      ]
    },
    "metadata": {
      "type": "object",
      "properties": {
        "annotations": {
          "description": "Annotations is an unstructured key value map stored with a resource that may be set by external tools to store and retrieve arbitrary metadata. They are not queryable and should be preserved when modifying objects. More info: http://kubernetes.io/docs/user-guide/annotations",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "labels": {
          "description": "Map of string keys and values that can be used to organize and categorize (scope and select) objects. May match selectors of replication controllers and services. More info: http://kubernetes.io/docs/user-guide/labels",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "name": {
          "description": "Name must be unique within a namespace. Is required when creating resources, although some resources may allow a client to request the generation of an appropriate name automatically. Name is primarily intended for creation idempotence and configuration definition. Cannot be updated. More info: http://kubernetes.io/docs/user-guide/identifiers#names",
          "type": "string"
        },
        "namespace": {
          "description": "Namespace defines the space within which each name must be unique. An empty namespace is equivalent to the \"default\" namespace, but \"default\" is the canonical representation. Not all objects are required to be scoped to a namespace - the value of this field for those objects will be empty. \n Must be a DNS_LABEL. Cannot be updated. More info: http://kubernetes.io/docs/user-guide/namespaces",
          "type": "string"
        }
      }
    },
    "spec": {
      "type": "object",
      "required": [
        "databaseRef",
        "type"
      ],
      "properties": {
        "apply": {
          "type": "string",
          "default": "IfReady",
          "enum": [
            "IfReady",
            "Always"
          ]
        },
        "databaseRef": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "default": ""
            }
          },
          "x-kubernetes-map-type": "atomic"
        },
        "maxRetries": {
          "type": "integer",
          "format": "int32",
          "default": 1
        },
        "restart": {
          "type": "object"
        },
        "timeout": {
          "type": "string"
        },
        "tls": {
          "type": "object",
          "properties": {
            "bolt": {
              "type": "object",
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": [
                    "Disabled",
                    "TLS",
                    "mTLS"
                  ]
                }
              }
            },
            "certificates": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "alias"
                ],
                "properties": {
                  "alias": {
                    "type": "string"
                  },
                  "dnsNames": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "duration": {
                    "type": "string"
                  },
                  "emailAddresses": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "ipAddresses": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "issuerRef": {
                    "type": "object",
                    "required": [
                      "kind",
                      "name"
                    ],
                    "properties": {
                      "apiGroup": {
                        "type": "string"
                      },
                      "kind": {
                        "type": "string"
                      },
                      "name": {
                        "type": "string"
                      }
                    },
                    "x-kubernetes-map-type": "atomic"
                  },
                  "privateKey": {
                    "type": "object",
                    "properties": {
                      "encoding": {
                        "type": "string",
                        "enum": [
                          "PKCS1",
                          "PKCS8"
                        ]
                      }
                    }
                  },
                  "renewBefore": {
                    "type": "string"
                  },
                  "secretName": {
                    "type": "string"
                  },
                  "subject": {
                    "type": "object",
                    "properties": {
                      "countries": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "localities": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "organizationalUnits": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "organizations": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "postalCodes": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "provinces": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "serialNumber": {
                        "type": "string"
                      },
                      "streetAddresses": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "uris": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "cluster": {
              "type": "object",
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": [
                    "Disabled",
                    "TLS",
                    "mTLS"
                  ]
                }
              }
            },
            "http": {
              "type": "object",
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": [
                    "Disabled",
                    "TLS",
                    "mTLS"
                  ]
                }
              }
            },
            "issuerRef": {
              "type": "object",
              "required": [
                "kind",
                "name"
              ],
              "properties": {
                "apiGroup": {
                  "type": "string"
                },
                "kind": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                }
              },
              "x-kubernetes-map-type": "atomic"
            },
            "keystoreCredSecret": {
              "type": "object",
              "required": [
                "kind",
                "name"
              ],
              "properties": {
                "activeFrom": {
                  "type": "string",
                  "format": "date-time"
                },
                "apiGroup": {
                  "type": "string",
                  "default": ""
                },
                "externallyManaged": {
                  "type": "boolean"
                },
                "kind": {
                  "type": "string",
                  "default": "Secret"
                },
                "name": {
                  "type": "string"
                },
                "rotateAfter": {
                  "type": "string"
                },
                "secretStoreName": {
                  "type": "string"
                }
              },
              "x-kubernetes-map-type": "atomic"
            },
            "remove": {
              "type": "boolean"
            },
            "rotateCertificates": {
              "type": "boolean"
            }
          }
        },
        "type": {
          "type": "string",
          "enum": [
            "Restart",
            "ReconfigureTLS"
          ]
        }
      }
    }
  }
}